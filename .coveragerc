[run]
omit =
    tests/*
    */test_*
    core/mqtt_bus.py
    core/ollama_service.py
    agents/ollama_agent.py
    monitoring/*
    gateway/*
    alembic/*
    scripts/*
    huggingface_space/*
    federation/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    raise ImportError
